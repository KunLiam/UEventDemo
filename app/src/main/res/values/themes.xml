<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 使用系统 Material 主题，避免 TV/Leanback 上 AppCompat+Material 控件组合 inflate 失败 -->
    <style name="Theme.UEventDemo" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/screen_bg</item>
        <item name="android:navigationBarColor">@color/screen_bg</item>
        <item name="android:windowBackground">@color/screen_bg</item>
        <item name="android:colorPrimary">@color/accent_cyan</item>
        <item name="android:colorAccent">@color/accent_cyan</item>
    </style>

    <style name="Theme.UEventDemo.WakeupPopup" parent="android:Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>
</resources>
